# MongoDB / DocumentDB Configuration
MONGODB_URL=mongodb://localhost:27017
DATABASE_NAME=claim_appeals
# For AWS DocumentDB (production), set these:
MONGODB_TLS=false
MONGODB_TLS_CA_FILE=/app/global-bundle.pem

# JWT Configuration
JWT_SECRET=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Azure Document Intelligence (OCR)
AZURE_OCR_ENDPOINT=https://your-azure-endpoint.cognitiveservices.azure.com/
AZURE_OCR_SECRET_KEY=your-azure-ocr-key

# AWS Credentials (for Bedrock LLM)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_SESSION_TOKEN=your-aws-session-token
AWS_REGION=us-east-1

# Google Gemini API
GEMINI_API_KEY=your-gemini-api-key

# Bedrock Configuration
BEDROCK_REGION=us-east-1

# Logging
LOG_LEVEL=INFO

# S3 Document Storage
S3_BUCKET=appeals-pgn-dev
S3_REGION=us-east-2
S3_PREFIX=documents
S3_PRESIGNED_EXPIRATION=3600
