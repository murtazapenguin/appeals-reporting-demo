# Claim Appeals V2 - Environment Variables
# Copy this file to .env and fill in the values

# ===========================================
# JWT Configuration
# ===========================================
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# ===========================================
# Azure Document Intelligence (OCR)
# ===========================================
AZURE_OCR_ENDPOINT=https://your-azure-endpoint.cognitiveservices.azure.com/
AZURE_OCR_SECRET_KEY=your-azure-ocr-key

# ===========================================
# AWS Credentials (for Bedrock LLM)
# ===========================================
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_SESSION_TOKEN=your-aws-session-token
AWS_REGION=us-east-1

# ===========================================
# Google Gemini API
# ===========================================
GEMINI_API_KEY=your-gemini-api-key

# ===========================================
# Bedrock Configuration
# ===========================================
BEDROCK_REGION=us-east-1

# ===========================================
# S3 Document Storage
# ===========================================
S3_BUCKET=appeals-pgn-dev
S3_REGION=us-east-2
S3_PREFIX=documents
S3_PRESIGNED_EXPIRATION=3600

# ===========================================
# Application Configuration
# ===========================================
LOG_LEVEL=INFO
VITE_API_BASE_URL=http://localhost:8000/api
